# ======================================================================
# terraform.tfvars.example — ПРИМЕР ФАЙЛА ПЕРЕМЕННЫХ
# Скопируйте в terraform.tfvars и заполните своими данными
# ======================================================================

cloud_id                 = "b1gxxxxxxxxxxxxxxxx"
folder_id                = "b1gxxxxxxxxxxxxxxxx"
default_zone             = "ru-central1-a"
service_account_key_file = "~/.config/yandex-cloud/sa-key.json"

environment = "prod"

vpc_name       = "app-network"
subnet_name    = "app-subnet"
v4_cidr_blocks = ["192.168.10.0/24"]

vm_name         = "vm-app"
image_family    = "ubuntu-2204-lts"
vm_cores        = 2
vm_memory       = 4
vm_disk_size    = 20
preemptible     = false

ssh_public_key    = "ssh-rsa AAAAB3NzaC1yc2EAAAA... your@email.com"
allowed_ssh_cidr  = "85.32.xx.xx/32"

# Сервисный аккаунт для ВМ (должен иметь роль container-registry.images.puller)
vm_service_account_id = "aje1234567890abcdef"

mysql_version   = "8.0"
mysql_db_name   = "appdb"
mysql_user      = "appuser"
mysql_password  = "YourStrongPassword123!"

registry_name = "app-registry"